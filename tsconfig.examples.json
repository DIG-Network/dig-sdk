{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@dignetwork/dig-sdk": ["./dist/index.d.ts"],
      "@dignetwork/dig-sdk/spend": ["./dist/spend.d.ts"],
      "@dignetwork/dig-sdk/dig-client": ["./dist/dig-client.d.ts"],
      "@dignetwork/dig-sdk/adapters": ["./dist/adapters.d.ts"],
      "@dignetwork/dig-sdk/vite": ["./dist/vite.d.ts"],
      "@dignetwork/dig-sdk/next": ["./dist/next.d.ts"]
    }
  },
  "include": ["examples"]
}
